@page "/plan-comptable"
@using Finama.Web.Models
@layout MainLayout
@inject FinamaApiService Api

<PageTitle>Plan comptable — Finama</PageTitle>

<div class="page-header d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <h1 class="page-title mb-1"><i class="bi bi-book-half me-2"></i>Plan comptable</h1>
        <p class="text-muted small mb-0">Référentiel OHADA — @(_comptes?.TotalItems ?? 0) comptes paramétrés</p>
    </div>
    <button class="btn btn-primary shadow-sm px-4 py-2" @onclick="OuvrirCreation">
        <i class="bi bi-plus-lg me-2"></i>Nouveau compte racine
    </button>
</div>

<div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-header bg-white py-3 border-bottom border-light">
        <div class="d-flex flex-wrap gap-3 align-items-center">

            <div class="flex-grow-1" style="min-width: 250px;">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control ps-5 py-2"
                           placeholder="Rechercher..."
                           value="@_recherche" @oninput="OnRechercheInput" />
                </div>
            </div>

            <div style="min-width: 200px;">
                <select class="form-select py-2"
                        value="@_filtreClasse"
                        @onchange="@(e => OnClasseChanged(e.Value?.ToString() ?? ""))">
                    <option value="">Toutes les classes</option>
                    <option value="1">Classe 1 — Capitaux</option>
                    <option value="2">Classe 2 — Immobilisations</option>
                    <option value="3">Classe 3 — Stocks</option>
                    <option value="4">Classe 4 — Tiers</option>
                    <option value="5">Classe 5 — Trésorerie</option>
                    <option value="6">Classe 6 — Charges</option>
                    <option value="7">Classe 7 — Produits</option>
                    <option value="8">Classe 8 — Spéciaux (H.A.O.)</option>
                    <option value="9">Classe 9 — Analytique</option>
                </select>
            </div>
        </div>
    </div>

    @if (_chargement)
    {
        <div class="d-flex flex-column justify-content-center align-items-center py-5 gap-2">
            <div class="spinner-border text-primary" role="status"></div>
            <span class="text-muted small">Chargement du plan comptable...</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase font-monospace" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-4 py-3" style="width: 15%">Numéro</th>
                        <th class="py-3" style="width: 40%">Libellé</th>
                        <th class="py-3">Classe</th>
                        <th class="py-3">Type</th>
                        <th class="text-center py-3">Norme</th>
                        <th class="text-center py-3">Statut</th>
                        <th class="text-end pe-4 py-3" style="width: 15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_comptes?.Items == null || !_comptes.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-50"></i>
                                Aucun compte comptable trouvé dans le système.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in _comptes.Items)
                        {
                            <tr @key="c.Id" class="@(!c.EstActif ? "opacity-60 bg-light-subtle" : "")">
                                <td class="ps-4">
                                    <span class="badge-code font-monospace fw-bold">@c.Numero</span>
                                </td>
                                <td>
                                    <div class="fw-semibold text-main">@c.Libelle</div>
                                    @if (!string.IsNullOrEmpty(c.CompteParentNumero))
                                    {
                                        <small class="text-muted text-xs d-block mt-1">
                                            <i class="bi bi-arrow-return-right me-1.5 text-primary"></i>Rattaché au compte : <span class="font-monospace fw-bold">@c.CompteParentNumero</span>
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="text-secondary small fw-medium">@c.LibelleClasse</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-secondary border border-light-subtle px-2.5 py-1 rounded-2 font-monospace small">@c.Type</span>
                                </td>
                                <td class="text-center">
                                    @if (c.EstSysteme)
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1 rounded-2 small fw-semibold">OHADA</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2.5 py-1 rounded-2 small fw-semibold">Local</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge-status @(c.EstActif ? "active" : "inactive")">
                                        <span class="badge-dot me-1.5"></span>@(c.EstActif ? "Actif" : "Inactif")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        @if (c.Numero.Length <= 4) @* 🌟 Ajouter un sous-compte uniquement si c'est un compte collectif racine *@
                                        {
                                            <button class="btn btn-sm btn-light border p-2 me-1.5 rounded-2 text-primary" title="Ajouter un sous-compte" @onclick="() => OuvrirCreationSousCompte(c)">
                                                <i class="bi bi-node-plus"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-light border p-2 me-1.5 rounded-2 text-secondary" title="Modifier" @onclick="() => OuvrirModification(c)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border p-2 rounded-2 @(c.EstActif ? "text-danger" : "text-success")"
                                                title="@(c.EstActif ? "Désactiver" : "Activer")" @onclick="() => ToggleStatut(c)">
                                            <i class="bi @(c.EstActif ? "bi-toggle-on" : "bi-toggle-off") fs-5 lh-1"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3 d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3 border-top border-light">
            <small class="text-muted font-monospace">Page @_page sur @(_comptes?.TotalPages ?? 1) (@(_comptes?.TotalItems ?? 0) comptes au total)</small>
            <div class="pagination-controls d-flex gap-1.5">
                <button class="btn btn-sm btn-light border px-3" disabled="@(_page <= 1)" @onclick="PagePrecedente">
                    <i class="bi bi-chevron-left me-1"></i> Précédent
                </button>
                <button class="btn btn-sm btn-light border px-3" disabled="@(_page >= (_comptes?.TotalPages ?? 1))" @onclick="PageSuivante">
                    Suivant <i class="bi bi-chevron-right ms-1"></i>
                </button>
            </div>
        </div>
    }
</div>

@if (_modalOuverte)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3 bg-card">
                <div class="modal-header border-bottom border-light px-4 py-3">
                    <div class="d-flex align-items-center gap-2.5">
                        <div class="bg-primary-subtle text-primary p-2 rounded-3 d-inline-flex">
                            <i class="bi @(_compteEdite is null ? (_parentSelectionne is null ? "bi-plus-circle-fill" : "bi-node-plus-fill") : "bi-pencil-square") fs-5"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0" style="color: var(--text-main);">
                                @if (_compteEdite is null)
                                {
                                    @(_parentSelectionne is null ? "Nouveau compte racine" : $"Nouveau sous-compte de {_parentSelectionne.Numero}")
                                }
                                else
                                {
                                    @("Modifier le compte")
                                }
                            </h5>
                            <span class="text-muted small">
                                @if (_compteEdite is null)
                                {
                                    @(_parentSelectionne is null ? "Ajouter un élément de niveau principal" : $"Hérite de la classe {_parentSelectionne.LibelleClasse}")
                                }
                                else
                                {
                                    @($"Édition du compte principal {_compteEdite.Numero}")
                                }
                            </span>
                        </div>
                    </div>
                    <button type="button" class="btn-close shadow-none" @onclick="FermerModal"></button>
                </div>
                <div class="modal-body px-4 py-3" style="color: var(--text-main);">
                    @if (!string.IsNullOrEmpty(_erreur))
                    {
                        <div class="alert alert-danger d-flex align-items-center py-2.5 border-0 shadow-sm mb-3 rounded-2 small" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-6"></i>
                            <div>@_erreur</div>
                        </div>
                    }

                    <div class="row g-3">
                        @if (_compteEdite is null)
                        {
                            <div class="col-12 col-sm-6">
                                <label class="form-label small fw-bold">Numéro de compte <span class="text-danger">*</span></label>
                                <input type="text" class="form-control py-2 font-monospace" @bind="_numero" placeholder="Ex: 411100" />
                                @if (_parentSelectionne is not null)
                                {
                                    <span class="text-primary text-xs d-block mt-1">
                                        <i class="bi bi-magic me-1"></i> Numéro suggéré automatiquement.
                                    </span>
                                }
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label small fw-bold">Classe OHADA <span class="text-danger">*</span></label>
                                <select class="form-select py-2" @bind="_classe" disabled="@(_parentSelectionne is not null)">
                                    @for (int i = 1; i <= 7; i++)
                                    {
                                        <option value="@i">Classe @i</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Type de structure <span class="text-danger">*</span></label>
                                <select class="form-select py-2" @bind="_type" disabled="@(_parentSelectionne is not null)">
                                    <option value="Bilan">Comptes de Bilan</option>
                                    <option value="ResultatCharge">Comptes de Résultat (Charges)</option>
                                    <option value="ResultatProduit">Comptes de Résultat (Produits)</option>
                                    <option value="Tresorerie">Comptes de Trésorerie</option>
                                </select>
                            </div>
                        }

                        <div class="col-12">
                            <label class="form-label small fw-bold">Libellé du compte <span class="text-danger">*</span></label>
                            <input type="text" class="form-control py-2" @bind="_libelle" placeholder="Ex: Clients ordinaires" />
                        </div>

                        @if (_compteEdite is not null)
                        {
                            <div class="col-12">
                                <label class="form-label small fw-bold">Validité de l'élément</label>
                                <select class="form-select py-2" @bind="_actif">
                                    <option value="true">Actif (Autoriser les imputations)</option>
                                    <option value="false">Inactif (Verrouiller et bloquer le compte)</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer border-top border-light px-4 py-3">
                    <button class="btn btn-light px-3.5 border" @onclick="FermerModal">Annuler</button>
                    <button class="btn btn-primary px-4" @onclick="Sauvegarder" disabled="@_sauvegarde">
                        @if (_sauvegarde)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Enregistrer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResultDto<CompteComptableDto>? _comptes;
    private bool _chargement = true;
    private bool _modalOuverte = false;
    private bool _sauvegarde = false;
    private string _erreur = "";
    private string _filtreClasse = "";
    private string? _recherche;
    private int _page = 1;
    private CompteComptableDto? _compteEdite;
    private CompteComptableDto? _parentSelectionne;

    private string _numero = "", _libelle = "", _type = "Bilan", _actif = "true";
    private int _classe = 4;

    protected override async Task OnInitializedAsync() => await ChargerAsync();

    private async Task ChargerAsync()
    {
        _chargement = true;

        // Sécurité : On s'assure que la page demandée n'est pas aberrante
        if (_page < 1) _page = 1;

        _comptes = await Api.GetPlanComptableAsync(
            classe: string.IsNullOrEmpty(_filtreClasse) ? null : _filtreClasse,
            recherche: _recherche,
            page: _page,
            pageSize: 50
        );

        // Ajustement de sécurité : Si après chargement la page courante dépasse le max de pages réelles
        if (_comptes is not null && _page > _comptes.TotalPages && _comptes.TotalPages > 0)
        {
            _page = _comptes.TotalPages;
            await ChargerAsync(); // Recharge la dernière page valide
        }

        _chargement = false;
    }

    // 🌟 Correction 1 : Gérer proprement le changement de classe
    private async Task OnClasseChanged(string nouvelleClasse)
    {
        _filtreClasse = nouvelleClasse;
        _page = 1; // Toujours revenir à la première page lors d'un changement de filtre
        await ChargerAsync();
    }

    // 🌟 Correction 2 : Sécurisation de l'input de recherche
    private async Task OnRechercheInput(ChangeEventArgs e)
    {
        _recherche = e.Value?.ToString();
        _page = 1; // Toujours revenir à la première page
        await ChargerAsync();
    }

    // 🌟 Correction 3 : Sécurisation des limites de pages
    private async Task PageSuivante()
    {
        if (_comptes is not null && _page < _comptes.TotalPages)
        {
            _page++;
            await ChargerAsync();
        }
    }

    private async Task PagePrecedente()
    {
        if (_page > 1)
        {
            _page--;
            await ChargerAsync();
        }
    }

    private void OuvrirCreation()
    {
        _compteEdite = null;
        _parentSelectionne = null;
        _numero = _libelle = ""; _type = "Bilan"; _classe = 4; _actif = "true";
        _erreur = ""; _modalOuverte = true;
    }

    private async Task OuvrirCreationSousCompte(CompteComptableDto parent)
    {
        _compteEdite = null;
        _parentSelectionne = parent;
        _libelle = "";
        _classe = parent.Classe;
        _type = parent.Type;
        _actif = "true";
        _erreur = "";
        _modalOuverte = true;

        try
        {
            _numero = await Api.GetProchainNumeroSousCompteAsync(parent.Id);
        }
        catch
        {
            _numero = $"{parent.Numero}01";
        }
    }

    private void OuvrirModification(CompteComptableDto c)
    {
        _compteEdite = c;
        _parentSelectionne = null;
        _libelle = c.Libelle; _actif = c.EstActif.ToString().ToLower();
        _erreur = ""; _modalOuverte = true;
    }

    private void FermerModal() { _modalOuverte = false; _erreur = ""; }

    private async Task ToggleStatut(CompteComptableDto c)
    {
        try
        {
            await Api.ChangerStatutCompteAsync(c.Id, !c.EstActif);
            await ChargerAsync();
        }
        catch (Exception ex) { _erreur = ex.Message; }
    }

    private async Task Sauvegarder()
    {
        if (string.IsNullOrWhiteSpace(_libelle)) { _erreur = "Le libellé est obligatoire."; return; }
        if (_compteEdite is null && string.IsNullOrWhiteSpace(_numero)) { _erreur = "Le numéro est obligatoire."; return; }

        _sauvegarde = true; _erreur = "";
        try
        {
            if (_compteEdite is null)
            {
                await Api.CreerCompteAsync(new CreerCompteRequest(
                    Numero: _numero,
                    Libelle: _libelle,
                    Classe: _classe,
                    Type: _type,
                    CompteParentId: _parentSelectionne?.Id));
            }
            else
            {
                await Api.ModifierCompteAsync(_compteEdite.Id, new ModifierCompteRequest(
                    Libelle: _libelle,
                    EstActif: bool.Parse(_actif),
                    CompteParentId: _compteEdite.CompteParentId));
            }
            FermerModal();
            await ChargerAsync();
        }
        catch (Exception ex) { _erreur = ex.Message; }
        finally { _sauvegarde = false; }
    }
}