@page "/connexion"
@page "/login"
@using Blazored.LocalStorage
@using Finama.Web.Models
@using Finama.Web.Services
@layout EmptyLayout
@inject FinamaApiService Api
@inject NavigationManager Nav
@inject AppState State
@inject AuthenticationStateProvider AuthStateProvider
@inject ILocalStorageService LocalStorage

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="brand-logo">F</div>
            <h1 class="auth-title">
                @(_enAttenteDeOtp ? "Vérification de sécurité" : "Bienvenue sur Finama")
            </h1>
        </div>

        <EditForm Model="_model" OnValidSubmit="GererSoumissionGlobale">
            @if (!_enAttenteDeOtp)
            {
                <div class="form-group">
                    <label>Email professionnel</label>
                    <InputText @bind-Value="_model.Email" class="form-control" placeholder="nom@entreprise.com" />
                </div>
                <div class="form-group">
                    <label>Mot de passe</label>
                    <InputText @bind-Value="_model.MotDePasse" type="password" class="form-control" />
                </div>
            }
            else
            {
                <div class="form-group" style="text-align: center;">
                    <label style="margin-bottom: 12px; display: block; font-weight: 500;">
                        Un code de validation unique a été envoyé à l'adresse <strong>@_model.Email</strong>.
                    </label>
                    <p style="font-size: 13px; color: #666; margin-bottom: 15px;">Le code est valide pendant 10 minutes.</p>

                    <InputText @bind-Value="_codeOtp"
                               @onkeyup="GererEntreeClavier"
                               class="form-control"
                               placeholder="------"
                               maxlength="6"
                               style="text-align: center; font-size: 24px; letter-spacing: 8px; font-weight: bold; text-transform: uppercase;" />
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <p style="color:red; font-size: 13px; margin-bottom: 10px;">⚠️ @_errorMessage</p>
            }

            <button type="submit" class="btn-auth" disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <span>Vérification...</span>
                }
                else
                {
                    <span>@(_enAttenteDeOtp ? "Valider le code" : "Se connecter")</span>
                }
            </button>

            @if (_enAttenteDeOtp)
            {
                <div style="text-align: center; margin-top: 15px; display: flex; flex-direction: column; gap: 8px; align-items: center;">
                    <button type="button" class="auth-link" style="background: none; border: none; cursor: pointer; font-size: 13px; color: #007bff;"
                            @onclick="GererRenvoiOtp" disabled="@_isSubmitting">
                        ⏳ @(_isResending ? "Renvoi du code en cours..." : "Renvoyer un nouveau code")
                    </button>

                    <button type="button" class="auth-link" style="background: none; border: none; cursor: pointer; font-size: 12px; color: #666;"
                            @onclick="RetournerAuLogin" disabled="@_isSubmitting">
                        ↩️ Revenir à la saisie du mot de passe
                    </button>
                </div>
            }
        </EditForm>

        @if (!_enAttenteDeOtp)
        {
            <div class="auth-footer">
                <p>Pas encore de compte ? <a href="/inscription" @onclick="Inscription" class="auth-link">Créer un compte</a></p>
            </div>
        }
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string _codeOtp = string.Empty;
    private bool _enAttenteDeOtp = false;
    private bool _isSubmitting = false;
    private string? _errorMessage;
    private bool _isResending = false;

    protected override async Task OnInitializedAsync()
    {
        var estConfiance = await LocalStorage.GetItemAsync<string>("device_trusted");
        var expiration = await LocalStorage.GetItemAsync<string>("device_expiry");

        if (estConfiance == "true" && DateTime.Parse(expiration) > DateTime.UtcNow)
        {
            // ATTENTION : C'est ici le problème.
            // Si tu bypasses l'API ici, tu ne peux pas te connecter car
            // l'API n'aura pas généré ton JWT.
        }
    }

    private async Task GererSoumissionGlobale()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            if (!_enAttenteDeOtp)
            {
                // ─── ÉTAPE 1 : Appel initial au Login ───
                // Note adaptative : Ton Api.LoginAsync doit renvoyer un indicateur pour savoir si l'OTP est activé
                var resultatLogin = await Api.LoginAsync(_model.Email, _model.MotDePasse);

                if (resultatLogin != null)
                {
                    // Si l'API renvoie un succès mais que l'AccessToken est vide,
                    // ça veut dire que le mot de passe est bon et qu'on attend l'OTP !
                    if (string.IsNullOrEmpty(resultatLogin.AccessToken))
                    {
                        _enAttenteDeOtp = true;
                    }
                    else
                    {
                        // Si l'API renvoie directement un token (ex: en dev ou si OTP désactivé), on connecte direct
                        State.Utilisateur = resultatLogin;
                        Nav.NavigateTo("/");
                    }
                }
                else
                {
                    _errorMessage = "Identifiants invalides. Veuillez réessayer.";
                }
            }
            else
            {
                // ─── ÉTAPE 2 : Appel à l'Endpoint de vérification de l'OTP ───
                if (string.IsNullOrWhiteSpace(_codeOtp) || _codeOtp.Length < 6)
                {
                    _errorMessage = "Veuillez saisir un code OTP valide à 6 chiffres.";
                    return;
                }

                // Ici, tu appelles ton nouvel endpoint Swagger 'verify-otp' que ton ApiService doit mapper
                var authData = await Api.VerifyOtpAsync(_model.Email, _codeOtp);

                if (authData != null)
                {
                    State.Utilisateur = authData;
                    await LocalStorage.SetItemAsync("accessToken", authData.AccessToken);
                    State.Utilisateur = authData;
                    // Dans ta méthode de validation après succès de l'OTP
                    await LocalStorage.SetItemAsync("device_trusted", "true");
                    await LocalStorage.SetItemAsync("device_expiry", DateTime.UtcNow.AddDays(30).ToString());

                    // 3. 🛡️ LA PARTIE MANQUANTE : Notifier le système de sécurité
                    // Tu dois caster le provider vers ta classe personnalisée
                    if (AuthStateProvider is CustomAuthStateProvider customProvider)
                    {
                        customProvider.NotifyUserAuthentication(authData.AccessToken);
                    }
                    Nav.NavigateTo("/");
                }
                else
                {
                    _errorMessage = "Code OTP incorrect ou expiré.";
                }
            }
        }
        catch (Exception ex)
        {
            // Capture proprement les messages personnalisés renvoyés par ton middleware d'exception (ex: "Le code OTP a expiré.")
            _errorMessage = ex.Message.Contains("401") || ex.Message.Contains("Unauthorized")
                ? "Échec de l'authentification. Vérifiez vos informations."
                : $"Erreur : {ex.Message}";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task GererRenvoiOtp()
    {
        _isResending = true;
        _isSubmitting = true; // Bloque aussi le bouton principal pour éviter le spam
        _errorMessage = null;
        _codeOtp = string.Empty; // On vide l'ancien code expiré

        try
        {
            // On ré-appelle simplement le Login initial avec l'email et le mot de passe déjà stockés dans le modèle
            var resultatLogin = await Api.LoginAsync(_model.Email, _model.MotDePasse);

            if (resultatLogin != null && string.IsNullOrEmpty(resultatLogin.AccessToken))
            {
                // Le mail est reparti avec un nouveau code ! On affiche un petit message de succès temporaire
                _errorMessage = "✅ Un nouveau code OTP a été envoyé à votre adresse e-mail.";
            }
            else
            {
                _errorMessage = "Impossible de renvoyer le code. Veuillez réessayer ou revenir en arrière.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Erreur lors du renvoi du code de sécurité.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isResending = false;
            _isSubmitting = false;
        }
    }

    private async Task GererEntreeClavier(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_codeOtp))
        {
            await GererSoumissionGlobale();
        }
    }

    private void RetournerAuLogin()
    {
        _enAttenteDeOtp = false;
        _codeOtp = string.Empty;
        _errorMessage = null;
    }

    private async Task Inscription()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/inscription");
    }
}