        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
    }

    .text-main {
        color: var(--text-main, #1e293b);
    }
</style>

@code {
    private PagedResult<TiersDto> _resultat = new();
    private FiltreTiersQuery _filtre = new();
    private bool _showEditModal = false;
    private bool _isSubmitting = false;
    private bool _showDeleteModal = false;
    private bool _showCreateModal = false;

    private CreerTiersRequest _createModel = new();
    private TiersDto _selectedTiers;
    private ModifierTiersRequest _editModel = new();

    private List<CompteComptableDto> _comptesCollectifsDisponibles = new();

    // LISTE POUR STOCKER LES DEVISES ISSUES DE L'API
    private List<DeviseDto> _devisesDisponibles = new();

    protected override async Task OnInitializedAsync()
    {
        await ChargerDevises();
        await ChargerDonnees();
    }

    private async Task ChargerDonnees() => _resultat = await Api.ListerTiersAsync(_filtre);

    // CHARGEMENT DEPUIS TON ENDPOINT /api/Devises
    private async Task ChargerDevises()
    {
        try
        {
            // Remplace par ton modèle de DTO réel (ex: DeviseDto ou semblable)
            _devisesDisponibles = await Api.GetDevisesActivesAsync();
        }
        catch
        {
            // Sécurité au cas où l'API Devises renvoie une erreur
            _devisesDisponibles = new List<DeviseDto>
            {
                new DeviseDto("FCFA", "CFA", "Franc CFA", 1.0m)
            };
        }
    }

    // CHARGEMENT GLOBAL DU RÉFÉRENTIEL COMPTABLE (Partagé entre création et édition)
    private async Task ChargerComptesComptables()
    {
        if (!_comptesCollectifsDisponibles.Any())
        {
            try
            {
                var tousLesComptes = await Api.ListerComptesComptablesAsync();
                _comptesCollectifsDisponibles = tousLesComptes
                    .Where(c => c.Classe == 4)
                    .OrderBy(c => c.Numero)
                    .ToList();
            }
            catch
            {
                _comptesCollectifsDisponibles = new();
            }
        }
    }

    private async Task OnRechercheKeyUp(KeyboardEventArgs e) => await ChargerDonnees();

    private async Task ChangerPage(int delta) { _filtre.Page += delta; await ChargerDonnees(); }

    private async Task OuvrirCreation()
    {
        await ChargerComptesComptables();

        _createModel = new CreerTiersRequest
        {
            Type = 0,
            // Sélectionne la première devise de la liste par défaut ou FCFA
            Devise = _devisesDisponibles.FirstOrDefault()?.Code ?? "FCFA"
        };

        AjusterCompteCollectifParDefaut();
        _showCreateModal = true;
    }

    private void AjusterCompteCollectifParDefaut()
    {
        if (_createModel.Type == 0)
        {
            _createModel.CompteComptableId = _comptesCollectifsDisponibles.FirstOrDefault(c => c.Numero.StartsWith("411"))?.Id;
        }
        else if (_createModel.Type == 1)
        {
            _createModel.CompteComptableId = _comptesCollectifsDisponibles.FirstOrDefault(c => c.Numero.StartsWith("401"))?.Id;
        }
        else
        {
            _createModel.CompteComptableId = _comptesCollectifsDisponibles.FirstOrDefault(c => c.Numero.StartsWith("47"))?.Id ??
                                             _comptesCollectifsDisponibles.FirstOrDefault()?.Id;
        }
    }

    private async Task OuvrirEdition(TiersDto tiers)
    {
        _selectedTiers = tiers;
        await ChargerComptesComptables();

        _editModel = new ModifierTiersRequest
        {
            Nom = tiers.Nom,
            Email = tiers.Email,
            Telephone = tiers.Telephone,
            EstActif = tiers.EstActif,
            Code = tiers.Code,
            Adresse = tiers.Adresse,
            Devise = tiers.Devise ?? "FCFA",
            NINEA = tiers.NINEA,
            // Récupération de l'ID existant du compte associé au tiers pour l'édition
            CompteComptableId = tiers.CompteComptableId
        };
        _showEditModal = true;
    }

    private async Task SauvegarderModification()
    {
        _isSubmitting = true;
        try
        {
            var success = await Api.ModifierTiersAsync(_selectedTiers.Id, _editModel);
            if (success)
            {
                _showEditModal = false;
                await ChargerDonnees();
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ConfirmerSuppression(TiersDto tiers)
    {
        _selectedTiers = tiers;
        _showDeleteModal = true;
    }

    private async Task ExecuterSuppression()
    {
        if (_selectedTiers == null) return;

        var success = await Api.SupprimerTiersAsync(_selectedTiers.Id);
        if (success)
        {
            _showDeleteModal = false;
            await ChargerDonnees();
        }
    }

    private async Task ExecuterEnregistrement()
    {
        _isSubmitting = true;
        try
        {
            _createModel.TenantId = State.Utilisateur.TenantId;
            var resultat = await Api.CreerTiersAsync(_createModel);
            if (resultat != null)
            {
                _showCreateModal = false;
                await ChargerDonnees();
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string ObtenirBadgeStyle(string type) => type switch
    {
        "Client" or "0" => "bg-info-subtle text-info border border-info-subtle",
        "Fournisseur" or "1" => "bg-warning-subtle text-warning border border-warning-subtle",
        _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
    };

    private string ObtenirBadgeIcon(string type) => type switch
    {
        "Client" or "0" => "bi-wallet2",
        "Fournisseur" or "1" => "bi-truck",
        _ => "bi-arrow-left-right"
    };

    private string ObtenirLibelleType(string type) => type switch
    {
        "Client" or "0" => "Client",
        "Fournisseur" or "1" => "Fournisseur",
        _ => "Mixte"
    };
}